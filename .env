# ============================================
# Диапазон портов: 6000-6999
# Формат: ABXX, где:
#   A=6 (проект)
#   B=группа сервисов (0-9)
#   XX=номер внутри группы (00-99)
# ============================================

# Порты сервисов отвечающих за фронтенд 
# - port:60xx 

FRONTEND_PORT=6001

# Порты сервисов отвечающих за оркестрацию и управление задачами 
# - port:61xx 

EXPERIMENT_ORCHESTRATOR_PORT=6100
TASKER_PORT=6110

# Порты сервисов отвечающих за обучение ML моделей
# - port:62xx 

TRAINER_SERVICE_PORT=6200

# Порты сервисов отвечающих за поддержку ML моделей
# - port:63xx 

ARTIFACTS_SERVICE_PORT=6300
METRICS_SERVICE_PORT=6310
DEPLOYMENT_SERVICE_PORT=6320

# Порты сервисов отвечающих за работу агентов
# - port:64xx

AGENT_OFFICE_PORT=6400
AGENT_MONITORING_PORT=6410

# Порты сервисов отвечающих за работу с датасетами
# - port:65xx

DATASETS_SERVICE_PORT=6500

# Порты и настройки для бд

