# Зависимости (обычно не копируем, т.к. устанавливаем внутри контейнера)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Системные файлы
.DS_Store
Thumbs.db

# Файлы окружения (обычно не нужны в образе, т.к. передаются через переменные)
.env
.env.local
.env.*.local

# Репозиторий и CI/CD
.git
.gitignore
.gitlab
.github
