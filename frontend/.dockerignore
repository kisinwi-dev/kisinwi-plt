.svn

# Редакторы и IDE
.idea
.vscode
*.swp
*.swo
*~

# Логи и отчёты
coverage
*.log
*.tsbuildinfo

# Временные файлы
tmp
temp
*.tmp
*.temp

# Сборки (они создаются в продакшене, но для dev-образа не нужны)
dist
build

# Докер-файлы (обычно не нужны внутри образа)
Dockerfile
Dockerfile.dev
docker-compose*.yml
.dockerignore

